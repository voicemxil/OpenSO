# OpenSO public-API reverse proxy.
# Terminates HTTPS (automatic Let's Encrypt) for the UserApi so the HTTPS website (openso.org) and the
# email-verification links can reach it. API_DOMAIN is injected by docker-compose (default api.openso.org).
#
# Requirement: API_DOMAIN must resolve to this box and be DNS-only in Cloudflare (grey cloud), otherwise
# Cloudflare proxies the ACME HTTP-01 challenge and cert issuance fails. (If you'd rather keep it proxied,
# use a Cloudflare Origin certificate + the tls directive instead of automatic issuance.)
{$API_DOMAIN} {
	encode zstd gzip

	# 3D remesh pack: the launcher's ResourceCentral "3DModels" entry points at /launcher/remesh.
	# Redirect it to our self-built loose-file pack — the latest release of voicemxil/FSO.Remeshes
	# (a fork of riperiperi/FSO.Remeshes whose CI keeps emitting the loose `*-legacy.zip`). The
	# launcher's DownloadService follows the redirect chain. Kept here rather than baked into the
	# launcher so the pack source can be repointed without redistributing the launcher.
	redir /launcher/remesh https://github.com/voicemxil/FSO.Remeshes/releases/latest/download/freeso-remeshes-legacy.zip 302

	reverse_proxy freeso-server:9000
}
